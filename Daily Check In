<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Check In Menu</title>
  <style>
    * {
      box-sizing: border-box;
    }

    :root {
      --text: #1f2a44;
      --muted: #4b5b7c;
      --panel: #ffffff;
      --shadow: 0 14px 32px rgba(31, 42, 68, 0.12);
      --shadow-hover: 0 18px 36px rgba(31, 42, 68, 0.18);
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
      color: var(--text);
      padding: 24px;
    }

    .container {
      width: min(1100px, 100%);
      text-align: center;
    }

    h1 {
      margin: 0 0 12px;
      font-size: clamp(2rem, 4vw, 3.2rem);
      letter-spacing: 0.04em;
    }

    .subtitle {
      margin: 0 0 30px;
      font-size: clamp(1rem, 2vw, 1.15rem);
      color: var(--muted);
    }

    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 22px;
      align-items: stretch;
    }

    .menu-button {
      width: 100%;
      border: none;
      border-radius: 28px;
      padding: 30px 22px;
      min-height: 160px;
      font-size: 1.7rem;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
      color: #1f2a44;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .menu-button:hover,
    .menu-button:focus-visible {
      transform: translateY(-6px) scale(1.02);
      filter: brightness(1.02);
      box-shadow: var(--shadow-hover);
      outline: none;
    }

    .daily-btn { background: #dff4df; }
    .control-btn { background: #fff2cf; }
    .voice-btn { background: #dff0ff; }

    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(18, 29, 53, 0.42);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
      z-index: 20;
    }

    .overlay.open {
      display: flex;
    }

    .modal {
      width: min(760px, 100%);
      max-height: 90vh;
      overflow: auto;
      background: #ffffff;
      border-radius: 30px;
      box-shadow: 0 24px 50px rgba(20, 30, 55, 0.24);
      padding: 22px;
      text-align: left;
      animation: popIn 0.25s ease;
    }

    @keyframes popIn {
      from {
        transform: scale(0.94);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    .modal-top {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      margin-bottom: 18px;
    }

    .modal-title {
      margin: 0;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
    }

    .close-btn {
      border: none;
      background: #eef3fb;
      color: #233252;
      border-radius: 16px;
      padding: 12px 16px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
    }

    .close-btn:hover,
    .close-btn:focus-visible {
      background: #dde8f8;
      outline: none;
    }

    .option-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .option-item {
      width: 100%;
      display: grid;
      grid-template-columns: 62px 1fr;
      gap: 14px;
      align-items: center;
      border-radius: 20px;
      padding: 14px;
      background: #f8fbff;
      border: 2px solid #eef3fb;
      cursor: pointer;
      text-align: left;
      font-family: inherit;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .option-item:hover,
    .option-item:focus-visible {
      transform: scale(1.02);
      box-shadow: 0 10px 24px rgba(31, 42, 68, 0.1);
      background: #f2f8ff;
      outline: none;
    }

    .face {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.7rem;
      box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.08);
    }

    .red { background: #ffb8b8; }
    .orange { background: #ffd0a8; }
    .yellow { background: #fff3a8; }
    .blue { background: #cfe3ff; }
    .green { background: #cdeecf; }

    .line-1 {
      font-size: 1.08rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 4px;
    }

    .line-2 {
      font-size: 0.96rem;
      color: var(--muted);
      line-height: 1.35;
    }

    .tiny {
      display: inline-block;
      font-size: 0.88rem;
      font-weight: 700;
      margin-right: 8px;
      color: #33415c;
    }

    .praise {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(18, 29, 53, 0.35);
      z-index: 30;
      padding: 20px;
    }

    .praise.open {
      display: flex;
    }

    .praise-box {
      width: min(500px, 100%);
      background: #ffffff;
      border-radius: 28px;
      padding: 26px 24px;
      text-align: center;
      box-shadow: 0 24px 50px rgba(20, 30, 55, 0.22);
      animation: popIn 0.25s ease;
    }

    .praise-emoji {
      font-size: 3rem;
      margin-bottom: 12px;
    }

    .praise-title {
      margin: 0 0 10px;
      font-size: 1.9rem;
    }

    .praise-text {
      margin: 0 0 18px;
      font-size: 1.1rem;
      color: var(--muted);
      line-height: 1.5;
    }

    .praise-btn {
      border: none;
      background: #dff4df;
      color: #17341d;
      border-radius: 18px;
      padding: 14px 22px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
    }

    .praise-btn:hover,
    .praise-btn:focus-visible {
      background: #caebcb;
      outline: none;
    }

    .status {
      margin-top: 24px;
      min-height: 30px;
      font-size: 1rem;
      font-weight: 700;
      color: #33415c;
    }

    @media (max-width: 640px) {
      body {
        padding: 16px;
      }

      .menu-grid {
        grid-template-columns: 1fr;
      }

      .menu-button {
        min-height: 120px;
        font-size: 1.35rem;
      }

      .modal {
        padding: 18px;
      }

      .option-item {
        grid-template-columns: 54px 1fr;
      }

      .face {
        width: 44px;
        height: 44px;
        font-size: 1.45rem;
      }
    }
  </style>
</head>
<body>
  <main class="container">
    <h1>Choose a Check In Tool</h1>
    <p class="subtitle">Click one box. It will open on the screen by itself.</p>

    <section class="menu-grid">
      <button class="menu-button daily-btn" onclick="openMenu('dailyModal')">Daily Check In</button>
      <button class="menu-button control-btn" onclick="openMenu('controlModal')">Control Scale</button>
      <button class="menu-button voice-btn" onclick="openMenu('voiceModal')">Voice Volume Scale</button>
    </section>

    <div class="status" id="status">Choose one tool to begin.</div>
  </main>

  <div class="overlay" id="dailyModal" onclick="closeOnBackdrop(event, 'dailyModal')">
    <div class="modal">
      <div class="modal-top">
        <h2 class="modal-title">Daily Check In</h2>
        <button class="close-btn" onclick="closeMenu('dailyModal')">Back</button>
      </div>
      <div class="option-list">
        <button class="option-item" type="button" onclick="showPraise('You did a great job telling us how you feel!')">
          <div class="face red">😖</div>
          <div>
            <div class="line-1"><span class="tiny">5</span>Too Mad, Sick</div>
            <div class="line-2">Need a walk</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Thank you for sharing your feelings. Great job!')">
          <div class="face orange">😠</div>
          <div>
            <div class="line-1"><span class="tiny">4</span>Angry, Very Sad</div>
            <div class="line-2">Need some quiet time</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Good job checking in. You are doing well!')">
          <div class="face yellow">😟</div>
          <div>
            <div class="line-1"><span class="tiny">3</span>Nervous, Scared, Irritated</div>
            <div class="line-2">Tired, Need help</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Nice work sharing how you feel!')">
          <div class="face blue">🙂</div>
          <div>
            <div class="line-1"><span class="tiny">2</span>OK, No problem</div>
            <div class="line-2">Doing good</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Awesome job! Thank you for telling us!')">
          <div class="face green">😁</div>
          <div>
            <div class="line-1"><span class="tiny">1</span>Great, Happy</div>
            <div class="line-2">No worries</div>
          </div>
        </button>
      </div>
    </div>
  </div>

  <div class="overlay" id="controlModal" onclick="closeOnBackdrop(event, 'controlModal')">
    <div class="modal">
      <div class="modal-top">
        <h2 class="modal-title">Control Scale</h2>
        <button class="close-btn" onclick="closeMenu('controlModal')">Back</button>
      </div>
      <div class="option-list">
        <button class="option-item" type="button" onclick="showPraise('Great job telling us what your body is feeling!')">
          <div class="face red">🤯</div>
          <div>
            <div class="line-1"><span class="tiny">5</span>Explosion, Too Mad</div>
            <div class="line-2">Very out of control</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('You shared your feelings really well. Good job!')">
          <div class="face orange">😤</div>
          <div>
            <div class="line-1"><span class="tiny">4</span>Mad, Angry, Loud</div>
            <div class="line-2">Big feelings</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Thank you for checking in. Great work!')">
          <div class="face yellow">😬</div>
          <div>
            <div class="line-1"><span class="tiny">3</span>Nervous, Worried</div>
            <div class="line-2">Starting to feel uneasy</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Nice job sharing your emotions!')">
          <div class="face blue">😕</div>
          <div>
            <div class="line-1"><span class="tiny">2</span>OK, Little Uncomfortable</div>
            <div class="line-2">Needs a little support</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Wonderful job! You checked in successfully!')">
          <div class="face green">😌</div>
          <div>
            <div class="line-1"><span class="tiny">1</span>Calm, Restful</div>
            <div class="line-2">Feeling settled</div>
          </div>
        </button>
      </div>
    </div>
  </div>

  <div class="overlay" id="voiceModal" onclick="closeOnBackdrop(event, 'voiceModal')">
    <div class="modal">
      <div class="modal-top">
        <h2 class="modal-title">Voice Volume Scale</h2>
        <button class="close-btn" onclick="closeMenu('voiceModal')">Back</button>
      </div>
      <div class="option-list">
        <button class="option-item" type="button" onclick="showPraise('Good job using the voice scale!')">
          <div class="face red">😱</div>
          <div>
            <div class="line-1"><span class="tiny">5</span>Too Big, Too Loud</div>
            <div class="line-2">Scream</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Nice choice! You did a good job!')">
          <div class="face orange">🗣️</div>
          <div>
            <div class="line-1"><span class="tiny">4</span>Shout Loud</div>
            <div class="line-2">Outside only</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Great job showing your talking level!')">
          <div class="face yellow">😃</div>
          <div>
            <div class="line-1"><span class="tiny">3</span>OK, Talking</div>
            <div class="line-2">Hello</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Well done! You picked your voice level!')">
          <div class="face blue">🤫</div>
          <div>
            <div class="line-1"><span class="tiny">2</span>Little Talk, Whisper</div>
            <div class="line-2">Talk softly</div>
          </div>
        </button>
        <button class="option-item" type="button" onclick="showPraise('Amazing job! Thank you for letting us know!')">
          <div class="face green">🤐</div>
          <div>
            <div class="line-1"><span class="tiny">1</span>No Talking</div>
            <div class="line-2">No words</div>
          </div>
        </button>
      </div>
    </div>
  </div>

  <div class="praise" id="praisePopup">
    <div class="praise-box">
      <div class="praise-emoji">🎉</div>
      <h2 class="praise-title">Great job!</h2>
      <p class="praise-text" id="praiseText">Thank you for sharing how you feel.</p>
      <div class="confetti">🎊 🎉 ✨ 🎊 🎉 ✨ 🎊 🎉</div>
    </div>
  </div>

  <script>
    const confettiCanvas = document.createElement('canvas');
    confettiCanvas.style.position = 'fixed';
    confettiCanvas.style.top = 0;
    confettiCanvas.style.left = 0;
    confettiCanvas.style.width = '100%';
    confettiCanvas.style.height = '100%';
    confettiCanvas.style.pointerEvents = 'none';
    confettiCanvas.style.zIndex = 40;
    document.body.appendChild(confettiCanvas);

    const ctx = confettiCanvas.getContext('2d');

    function resizeCanvas() {
      confettiCanvas.width = window.innerWidth;
      confettiCanvas.height = window.innerHeight;
    }

    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function launchConfetti() {
      const pieces = [];
      const colors = ['#ff6b6b','#ffd93d','#6bcB77','#4d96ff','#ff9f1c','#c77dff'];

      for (let i = 0; i < 120; i++) {
        pieces.push({
          x: Math.random() * confettiCanvas.width,
          y: -10,
          size: 6 + Math.random() * 6,
          speed: 2 + Math.random() * 3,
          color: colors[Math.floor(Math.random()*colors.length)],
          tilt: Math.random() * 10
        });
      }

      let frame = 0;

      function animate() {
        ctx.clearRect(0,0,confettiCanvas.width,confettiCanvas.height);

        pieces.forEach(p => {
          p.y += p.speed;
          p.x += Math.sin(frame/10);

          ctx.fillStyle = p.color;
          ctx.fillRect(p.x, p.y, p.size, p.size);
        });

        frame++;

        if (frame < 120) {
          requestAnimationFrame(animate);
        } else {
          ctx.clearRect(0,0,confettiCanvas.width,confettiCanvas.height);
        }
      }

      animate();
    }

    function openMenu(id) {
      document.getElementById(id).classList.add('open');
      document.getElementById('status').textContent = 'Menu opened.';
    }

    function closeMenu(id) {
      document.getElementById(id).classList.remove('open');
      document.getElementById('status').textContent = 'Choose one tool to begin.';
    }

    function closeOnBackdrop(event, id) {
      if (event.target.id === id) {
        closeMenu(id);
      }
    }

    function showPraise(message) {
      const popup = document.getElementById('praisePopup');
      const text = document.getElementById('praiseText');

      text.textContent = message;
      popup.classList.add('open');

      launchConfetti();

      setTimeout(() => {
        popup.classList.remove('open');
        document.querySelectorAll('.overlay').forEach(m => m.classList.remove('open'));
        document.getElementById('status').textContent = 'Great job checking in!';
      }, 2500);
    }
  </script>
</body>
</html>
